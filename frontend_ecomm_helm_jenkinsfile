pipeline {
    
    agent any
    
    tools {
        maven "maven"
    }

    environment {
        AWS_REGION = "us-east-1"
        ECR = "907260787494.dkr.ecr.us-east-1.amazonaws.com"
        ECR_REPO = "907260787494.dkr.ecr.us-east-1.amazonaws.com/ecomm_store"
        IMAGE_TAG = "latest"
        HELM_CHART = "ecomm-chart"
    }

    stages {

        stage ('Git Clone') {
            steps {
                git branch: 'main',
                credentialsId: 'gitcred',
                url: 'https://github.com/vishwajeetkore/ecomm_store.git'
            }
        }

        stage ('Docker Build') {
            steps {
                sh 'docker build -t ecomm_store .'
                sh 'docker tag ecomm_store:$IMAGE_TAG $ECR_REPO:$IMAGE_TAG'
            }
        }

        stage ('ECR Login') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'awscred'
                ]]) {
                    sh '''
                    aws ecr get-login-password --region $AWS_REGION | \
                    docker login --username AWS --password-stdin $ECR
                    '''
                }
            }
        }

        stage ('Docker Push') {
            steps {
                sh 'docker push $ECR_REPO:$IMAGE_TAG'
            }
        }

        stage('Deploy') {
    steps {
        sh '''
        helm uninstall $HELM_CHART || true

        cd $HELM_CHART
        helm upgrade --install $HELM_CHART . --force
        '''
    }
}

    }
}
